        </td>
      </tr>

      <!-- Payment Expired -->
      <tr>
        <td style="background:#e8eaf6; border-top:3px solid #7986cb; padding:22px; text-align:center; color:#3949ab;">
          <p style="margin:0; font-size:1.15em;"><strong>𝗬o𝘂𝗿 𝗽𝗮𝘆𝗺𝗲𝗻𝘁 𝗺𝗲𝘁𝗵𝗼𝗱 𝗵𝗮𝘀 𝗲𝘅𝗽𝗶𝗿𝗲𝗱.</strong></p>
          <p style="margin:10px 0 0;">𝗣𝗹𝗲𝗮𝘀𝗲 𝘂𝗽𝗱𝗮𝘁𝗲 𝘆𝗼𝘂𝗿 𝗽𝗮𝘆𝗺𝗲𝗻𝘁 𝗶𝗻𝗳𝗼𝗿𝗺𝗮𝘁𝗶𝗼𝗻 𝘁𝗼 𝗮𝘃𝗼𝗶𝗱 𝘀𝗲𝗿𝘃𝗶ce 𝗶𝗻𝘁𝗲𝗿𝗿𝘂𝗽𝘁i𝗼𝗻.</p>
        </td>
      </tr>

      <!-- Message -->
      <tr>
        <td style="padding:22px; color:#4a4a4a; text-align:center; background:#fcfcfc;">
          𝗜𝗳 𝘆𝗼𝘂 𝗮𝗿𝗲 𝗿𝘂𝗻𝗻𝗶𝗻𝗴 𝗼𝘂𝘁 𝗼𝗳 𝘀𝗽𝗮𝗰𝗲, 𝗰𝗼𝗻𝘀𝗶𝗱𝗲𝗿 𝘂𝗽𝗴𝗿ading 𝘆𝗼𝘂𝗿 𝗰𝗹𝗼𝘂𝗱 𝗽𝗹𝗮𝗻 𝗻𝗼𝘄.
        </td>
      </tr>

      <!-- Disabled Account -->
      <tr>
        <td style="background:#DA05ED; color:#fff; text-align:center; padding:17px;">
          <p style="margin:0; font-size:1.15em; font-weight:bold;">𝗬𝗼𝘂𝗿 𝗖𝗹𝗼𝘂𝗱 𝗔𝗰𝗰𝗼𝘂𝗻𝘁 𝗶𝘀 𝗗𝗶𝘀𝗮𝗯𝗹𝗲𝗱</p>
        </td>
      </tr>

      <!-- Renewal Failure -->
      <tr>
        <td style="background:#F2BD1F; color:#fff; text-align:center; padding:20px;">
          <p style="margin:0;">𝗪𝗲 𝗰𝗼𝘂𝗹𝗱𝗻'𝘁 𝗿𝗲𝗻𝗲𝘄 𝘆𝗼𝘂𝗿 𝗖𝗹𝗼𝘂𝗱 𝘀𝘂𝗯𝘀𝗰𝗿𝗶𝗽𝘁𝗶𝗼𝗻.</p>
          <p style="margin:8px 0 0;">𝗪𝗶𝘁𝗵𝗼𝘂𝘁 𝗮𝘃𝗮𝗶𝗹𝗮𝗯𝗹𝗲 𝘀𝗽𝗮𝗰𝗲, 𝘆𝗼𝘂𝗿 𝘀𝘁𝗼𝗿𝗲𝗱 𝗱𝗮𝘁𝗮 𝗮𝗻𝗱 𝗳𝗶𝗹𝗲𝘀 𝘄𝗶𝗹𝗹 𝗯𝗲 𝗽𝗲𝗿𝗺𝗮𝗻𝗲𝗻𝘁𝗹𝘆 𝗱𝗲𝗹𝗲𝘁𝗲𝗱.</p>
        </td>
      </tr>

      <!-- Order Details -->
      <tr>
        <td style="background:#c5cae9; text-align:center; padding:22px;">
          <p style="font-weight:bold; font-size:1.15em; margin:0 0 10px;">𝗢𝗿𝗱𝗲𝗿 𝗗𝗲𝘁𝗮𝗶𝗹𝘀:</p>
          <p style="margin:0;"><strong>𝗦𝘂𝗯𝘀𝗰𝗿𝗶𝗽𝘁𝗶𝗼𝗻 𝗣𝗹𝗮𝗻:</strong> 𝟮𝟱𝟬𝗚𝗕</p>
          <p style="margin:6px 0;"><strong>𝗣𝗿𝗼𝗱𝘂𝗰𝘁:</strong> 𝗖𝗹𝗼𝘂𝗱 𝗦𝘁𝗼𝗿𝗮𝗴𝗲</p>
          <p style="margin:6px 0 0;"><strong>𝗘𝘅𝗽𝗶𝗿𝗮𝘁𝗶𝗼𝗻 𝗗𝗮𝘁𝗲:</strong> 𝗧𝗼𝗱𝗮𝘆</p>
        </td>
      </tr>

      <!-- Final Warning -->
      <tr>
        <td style="background:#ffebee; border-top:2px solid #ef9a9a; color:#d32f2f; text-align:center; padding:22px;">
          <p style="margin:0;"><strong>𝗙𝗶𝗻𝗮𝗹 𝗪𝗮𝗿𝗻𝗶𝗻𝗴: 𝗗𝗮𝘁𝗮 𝗱𝗲𝗹𝗲𝘁𝗶𝗼𝗻 𝗶𝗻 𝗽𝗿𝗼𝗴𝗿𝗲𝘀𝘀.</strong></p>
          <p style="margin:10px 0 0;"><strong>𝗬𝗼𝘂𝗿 𝗮𝗰𝗰𝗼𝘂𝗻𝘁 𝗶𝘀 𝗯𝗹𝗼𝗰𝗸𝗲𝗱ⵑ 𝗔𝗹𝗹 𝘆𝗼𝘂𝗿 𝗽𝗵𝗼𝘁𝗼𝘀 𝗮𝗻𝗱 𝘃𝗶𝗱𝗲𝗼𝘀 𝘄𝗶𝗹𝗹 𝗯𝗲 𝗱𝗲𝗹𝗲𝘁𝗲𝗱 𝘁𝗼𝗱𝗮𝘆ⵑ</strong></p>
