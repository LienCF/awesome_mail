      /* --------------------------------
      price-drop-4.2.0
      -------------------------------- */
      .product-row {
        background-color: rgb(250, 117, 102);
        width: 100%;
        max-width: 760px;
        padding-bottom: 4px;
      }
      .product-card {
        padding: 8px;
        padding-bottom: 4px;
        max-width: 380px;
        max-height: 560px;
      }
      .product-card_left {
        padding-left: 16px;
      }
      .product-card_right {
        padding-right: 16px;
      }
      .product-card-table {
        border-radius: 8px;
        border-width: 4px 5px;
        border-style: solid;
        border-color: #ffe71e;
      }
      .product-card-table img {
        width: 100%;
        border-radius: 4px 4px 0 0;
        border-width: 4px 4px;
        height: auto;
      }
      .product-card-table {
      }
      .product-card-table .content {
        padding: 8px;
        background-color: #ffe71e;
      }

      .product-card-promo-label {
        color: #6001d2 !important;
        text-decoration: none;
        border-width: 0;
        width: 100%;
        display: block;
        overflow: hidden;
        margin: 0 auto;
        font-size: 21px;
        font-weight: 700;
        text-align: left;
        display: block !important;
        white-space: normal;
        line-height: 28px;
        max-height: 28px;
        height: 28px;
        min-height: 28px;
      }

      .product-card-promo-label_empty {
        line-height: 28px;
        max-height: 28px;
        height: 28px;
        min-height: 28px;
        color: transparent;
        display: block !important;
      }

      .product-card-title {
        width: 100%;
        max-height: 60px;
        min-height: 60px;
        height: 60px;
        display: block;
        line-height: 30px;
        white-space: normal;
        -webkit-line-clamp: 2;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 21px;
        font-weight: 700;
        display: block !important;
      }

      .product-card-title a {
        text-decoration: none;
        color: black;
      }

      .product-card-price {
        text-align: right;
      }

      .product-card-price__orig {
        font-size: 16px;
        font-weight: 400;
        line-height: 36px;
        text-decoration: line-through;
      }

      .product-card-price__promo {
        color: #eb0f29;
        font-size: 60px;
        font-weight: 700;
        line-height: 70px;
        text-align: center;
      }

      .product-card-price__promo_dollar {
        font-size: 24px;
        font-weight: 700;
        line-height: 36px;
      }

      .dont-stack th {
        display: table-cell !important;
      }

      @media screen and (max-width: 400px) {
        .product-card-title {
          font-size: 16px;
          line-height: 20px;
        }
        .product-card-promo-label {
          font-size: 16px;
          line-height: 26px;
        }
        .product-card-price__promo {
          font-size: 28px;
          line-height: 54px;
        }
      }

      @media screen and (min-width: 401px) and (max-width: 450px) {
        .product-card-title {
          font-size: 17px;
          line-height: 26px;
        }
        .product-card-promo-label {
          font-size: 18px;
          line-height: 26px;
        }
        .product-card-price__promo {
          font-size: 32px;
          line-height: 50px;
        }
      }

      @media screen (max-width: 500px) {

        .product-card .colspan2 {
          overflow: hidden;
        }
        .product-card_left {
          padding-left: 8px;
          padding-right: 4px;
        }
        .product-card_right {
          padding-right: 8px;
          padding-left: 4px;
        }
        .product-card-title {
          font-size: 18px;
          max-height: 40px;
          min-height: 40px;
          height: 40px;
          line-height: 24px;
        }
        .product-card-price__promo {
          font-size: 36px;
          line-height: 56px;
        }
        .product-card-promo-label {
          font-size: 18px;
          max-height: 18px;
          min-height: 18px;
          height: 18px;
          line-height: 26px;
        }
        .product-card-promo-label_empty {
          font-size: 18px;
          max-height: 18px;
          min-height: 18px;
          height: 18px;
          line-height: 22px;
          color: transparent;
        }
      }


